generator client {
  provider = "prisma-client-js"
  output   = "./client" 
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  discordId       String   @unique
  encryptedWallet String
  createdAt       DateTime @default(now())
}